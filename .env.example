# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Backend API Base URL for Android communication
BACKEND_URL=https://ais-dev-qqngeehygsub7x2dlkecmv-192238933313.us-west2.run.app

# Melipayamak API Credentials
MELIPAYAMAK_USERNAME=MELIPAYAMAK_USERNAME_PLACEHOLDER
MELIPAYAMAK_PASSWORD=MELIPAYAMAK_PASSWORD_PLACEHOLDER

# Google Sign-In Server Client ID (Firebase Auth Option)
