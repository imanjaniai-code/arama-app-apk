# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Melipayamak API Credentials
MELIPAYAMAK_USERNAME=MELIPAYAMAK_USERNAME_PLACEHOLDER
MELIPAYAMAK_PASSWORD=MELIPAYAMAK_PASSWORD_PLACEHOLDER

# Google Sign-In Server Client ID (Firebase Auth Option)
GOOGLE_SERVER_CLIENT_ID=1092837491-dummy.apps.googleusercontent.com

# Payping Token (for Persian payment gateway integration)
PAYPING_API_KEY=PAYPING_API_KEY_PLACEHOLDER
